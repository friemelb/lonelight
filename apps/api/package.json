    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "tsc-alias": "^1.8.8",
    "vitest": "^1.1.0",
    "supertest": "^6.3.3"
