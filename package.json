{
  "name": "loanlens",
  "version": "0.1.0",
  "private": true,
  "description": "Intelligent document extraction system for loan documents",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:domain": "npm run build --workspace=packages/domain",
    "test": "npm run test --workspaces",
    "test:api": "npm run test --workspace=apps/api",
    "test:web": "npm run test --workspace=apps/web",
    "test:domain": "npm run test --workspace=packages/domain",
    "type-check": "npm run type-check --workspaces",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist packages/*/node_modules packages/*/dist",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "document-extraction",
    "loan-processing",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "docx": "^9.6.1",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "unpdf": "^1.6.2"
  }
}
